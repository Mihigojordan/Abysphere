model PurchaseOrder {
  id                   String               @id @default(uuid())
  poNumber             String               @unique
  supplierId           String
  orderDate            DateTime             @default(now())
  expectedDeliveryDate DateTime?
  status               POStatus             @default(DRAFT)
  subtotal             Decimal              @default(0.00) @db.Decimal(14, 2)
  taxAmount            Decimal              @default(0.00) @db.Decimal(14, 2)
  shippingCost         Decimal              @default(0.00) @db.Decimal(14, 2)
  otherCharges         Decimal              @default(0.00) @db.Decimal(14, 2)
  grandTotal           Decimal              @default(0.00) @db.Decimal(14, 2)
  paymentTerms         String?
  deliveryTerms        String?
  notes                String?              @db.Text
  internalNotes        String?              @db.Text
  createdByAdminId     String?
  createdByEmployeeId  String?
  approvedAt           DateTime?
  approvedByAdminId    String?
  approvedByEmployeeId String?
  closedAt             DateTime?
  cancelledAt          DateTime?
  cancellationReason   String?              @db.Text
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  approvals            ApprovalWorkflow[]
  documents            DocumentAttachment[]
  grns                 GoodsReceivingNote[]
  approvedByAdmin      Admin?               @relation("POApprovedByAdmin", fields: [approvedByAdminId], references: [id])
  approvedByEmployee   Employee?            @relation("POApprovedByEmployee", fields: [approvedByEmployeeId], references: [id])
  createdByAdmin       Admin?               @relation("POCreatedByAdmin", fields: [createdByAdminId], references: [id])
  createdByEmployee    Employee?            @relation("POCreatedByEmployee", fields: [createdByEmployeeId], references: [id])
  supplier             Supplier             @relation(fields: [supplierId], references: [id])
  items                PurchaseOrderItem[]

  @@index([poNumber])
  @@index([supplierId])
  @@index([status])
  @@index([approvedByAdminId], map: "PurchaseOrder_approvedByAdminId_fkey")
  @@index([approvedByEmployeeId], map: "PurchaseOrder_approvedByEmployeeId_fkey")
  @@index([createdByAdminId], map: "PurchaseOrder_createdByAdminId_fkey")
  @@index([createdByEmployeeId], map: "PurchaseOrder_createdByEmployeeId_fkey")
}

model PurchaseOrderItem {
