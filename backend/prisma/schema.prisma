model ProformaInvoice {
  id              String         @id @default(uuid())
  proformaNumber  String         @unique
  clientName      String
  clientEmail     String?
  clientPhone     String?
  issueDate       DateTime       @default(now())
  expiryDate      DateTime?
  status          ProformaStatus @default(DRAFT)
  subtotal        Decimal        @default(0) @db.Decimal(14, 2)
  taxAmount       Decimal        @default(0) @db.Decimal(14, 2)
  discountType    String?
  discountValue   Decimal        @default(0) @db.Decimal(14, 2)
  grandTotal      Decimal        @default(0) @db.Decimal(14, 2)
  paymentTerms    String?
  notes           String?        @db.Text
  paidAt          DateTime?
  cancelledAt     DateTime?
  cancellationReason String?     @db.Text
  createdByAdminId    String?
  createdByAdmin      Admin?     @relation("ProformaCreatedByAdmin", fields: [createdByAdminId], references: [id])
  createdByEmployeeId String?
  createdByEmployee   Employee?  @relation("ProformaCreatedByEmployee", fields: [createdByEmployeeId], references: [id])
  approvedByAdminId   String?
  approvedByAdmin     Admin?     @relation("ProformaApprovedByAdmin", fields: [approvedByAdminId], references: [id])
  approvedByEmployeeId String?
  approvedByEmployee  Employee?  @relation("ProformaApprovedByEmployee", fields: [approvedByEmployeeId], references: [id])
  items           ProformaInvoiceItem[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([createdByAdminId])
  @@index([approvedByAdminId])
}

model ProformaInvoiceItem {
  id                String          @id @default(uuid())
  proformaInvoiceId String
  proformaInvoice   ProformaInvoice @relation(fields: [proformaInvoiceId], references: [id], onDelete: Cascade)
  stockId           Int?
  stock             Stock?          @relation(fields: [stockId], references: [id])
  productName       String
  productSku        String?
  description       String?         @db.Text
  quantity          Int
  unitPrice         Decimal         @db.Decimal(14, 2)
  discountPct       Decimal?        @default(0) @db.Decimal(5, 2)
  taxPct            Decimal?        @default(0) @db.Decimal(5, 2)
  totalPrice        Decimal         @db.Decimal(14, 2)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([proformaInvoiceId])
  @@index([stockId])
}
