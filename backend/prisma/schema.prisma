generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id           String      @id @unique @default(uuid())
  adminName    String?
  adminEmail   String?     @unique
  phone        String?
  password     String?
  profileImage String?
  status       AdminStatus @default(ACTIVE)
  google_id    String?     @unique
  is2FA        Boolean?    @default(false)
  isLocked     Boolean?    @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model SystemFeature {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?        @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  admins      AdminFeature[]
}

model DemoRequest {
  id                 Int      @id @default(autoincrement())
  fullName           String
  email              String
  phone              String
  companyName        String
  companyWebsite     String?
  companyDescription String?
  companySize        String?
  message            String?
  status             String   @default("pending")
  createdAt          DateTime @default(now())
}

model AdminFeature {
  adminId   String
  featureId String
  createdAt DateTime      @default(now())
  admin     Admin         @relation(fields: [adminId], references: [id], onDelete: Cascade)
  feature   SystemFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([adminId, featureId])
  @@index([featureId], map: "AdminFeature_featureId_fkey")
}

model Admin {
  id                     String               @id @unique @default(uuid())
  adminName              String?
  adminEmail             String?              @unique
  phone                  String?
  password               String?
  profileImage           String?
  status                 AdminStatus          @default(ACTIVE)
  google_id              String?              @unique
  website                String?
  address                String?
  city                   String?
  country                String?
  description            String?
  message                String?
  messageExpiry          DateTime?
  isMessage              Boolean?             @default(false)
  is2FA                  Boolean?             @default(false)
  isLocked               Boolean?             @default(false)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  messageBgColor         String?
  messageTextColor       String?
  Activity               Activity[]
  features               AdminFeature[]
  alertsAcknowledged     AlertNotification[]  @relation("AlertAcknowledgedByAdmin")
  approvalsApproved      ApprovalWorkflow[]   @relation("ApprovalApprovedByAdmin")
  approvalsRequested     ApprovalWorkflow[]   @relation("ApprovalRequestedByAdmin")
  category               Category[]
  client                 Client[]
  Debit                  Debit[]
  documentsUploaded      DocumentAttachment[] @relation("DocUploadedByAdmin")
  employee               Employee[]
  expenses               Expense[]
  grnsApproved           GoodsReceivingNote[] @relation("GRNApprovedByAdmin")
  grnsReceived           GoodsReceivingNote[] @relation("GRNReceivedByAdmin")
  medications            Medication[]
  membershipPlans        MembershipPlan[]
  purchaseOrdersApproved PurchaseOrder[]      @relation("POApprovedByAdmin")
  purchaseOrdersCreated  PurchaseOrder[]      @relation("POCreatedByAdmin")
  proformasCreated       ProformaInvoice[]    @relation("ProformaCreatedByAdmin")
  proformasApproved      ProformaInvoice[]    @relation("ProformaApprovedByAdmin")
  closedBy               Request[]            @relation("ClosedByAdmin")
  issuedBy               Request[]            @relation("IssuedByAdmin")
  rejectedBy             Request[]            @relation("rejectedByAdmin")
  requestedBy            Request[]            @relation("RequestedByAdmin")
  Stock                  Stock[]
  stockHistoriesCreated  StockHistory[]
  stockout               StockOut[]
  store                  Store[]
  suppliers              Supplier[]
}

model MembershipPlan {
  id               String   @id @default(uuid())
  companyId        String
  planName         String
  startTime        DateTime
  expireTime       DateTime
  amountPaid       Float
  shortDescription String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Admin    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Employee {
  id                         String                       @id @unique @default(uuid())
  first_name                 String?
  last_name                  String?
  gender                     String?
  phone                      String?
  email                      String                       @unique
  password                   String?
  national_id                String?                      @unique
  profile_picture            String?
  position                   String?
  date_hired                 DateTime?
  status                     EmployeeStatus               @default(ACTIVE)
  emergency_contact_name     String?
  emergency_contact_phone    String?
  adminId                    String
  google_id                  String?                      @unique
  isLocked                   Boolean?                     @default(false)
  is2FA                      Boolean?                     @default(false)
  siteId                     String?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  department                 String?
  activity                   Activity[]
  alertsAcknowledged         AlertNotification[]          @relation("AlertAcknowledgedByEmployee")
  approvalsApproved          ApprovalWorkflow[]           @relation("ApprovalApprovedByEmployee")
  approvalsRequested         ApprovalWorkflow[]           @relation("ApprovalRequestedByEmployee")
  AssetRequest               AssetRequest[]
  category                   Category[]
  contract                   Contract[]
  Debit                      Debit[]
  documentsUploaded          DocumentAttachment[]         @relation("DocUploadedByEmployee")
  eggFishFeeding             EggFishFeeding[]
  EggFishMedication          EggFishMedication[]
  eggToPondMigration         EggToPondMigration[]
  admin                      Admin                        @relation(fields: [adminId], references: [id])
  site                       Site?                        @relation("SiteEmployees", fields: [siteId], references: [id])
  feeds                      FeedCage[]
  grnsApproved               GoodsReceivingNote[]         @relation("GRNApprovedByEmployee")
  grnsReceived               GoodsReceivingNote[]         @relation("GRNReceivedByEmployee")
  grownEggPondFeeding        GrownEggPondFeeding[]
  laboratoryBoxWaterChanging LaboratoryBoxWaterChanging[]
  medications                Medication[]
  medicines                  Medicine[]
  parentEggMigration         ParentEggMigration[]
  ParentFishFeeding          ParentFishFeeding[]
  ParentFishMedication       ParentFishMedication[]
  parentFishPools            ParentFishPool[]
  parentWaterChanging        ParentWaterChanging[]
  PondMedication             PondMedication[]
  PondWaterChanging          PondWaterChanging[]
  purchaseOrdersApproved     PurchaseOrder[]              @relation("POApprovedByEmployee")
  purchaseOrdersCreated      PurchaseOrder[]              @relation("POCreatedByEmployee")
  proformasCreated           ProformaInvoice[]            @relation("ProformaCreatedByEmployee")
  proformasApproved          ProformaInvoice[]            @relation("ProformaApprovedByEmployee")
  closedBy                   Request[]                    @relation("ClosedByEmployee")
  issuedBy                   Request[]                    @relation("IssuedByEmployee")
  rejectedBy                 Request[]                    @relation("rejectedByEmployee")
  requestedBy                Request[]                    @relation("RequestedByEmployee")
  managedSites               Site[]                       @relation("ManagerRelation")
  supervisedSites            Site[]                       @relation("SupervisorRelation")
  stockHistoriesCreated      StockHistory[]
  stockLocationsManaged      StockLocation[]
  stockout                   StockOut[]
  store                      Store[]

  @@index([adminId], map: "Employee_adminId_fkey")
  @@index([siteId], map: "Employee_siteId_fkey")
}

model Contract {
  id                    String       @id @default(uuid())
  employeeId            String?
  contractType          ContractType
  startDate             DateTime
  endDate               DateTime?
  salary                Float
  currency              String       @default("RWF")
  benefits              String?
  workingHours          String?
  probationPeriod       String?
  terminationConditions String?
  terms                 String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  employee              Employee?    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId], map: "Contract_employeeId_fkey")
}

model Stock {
  id                Int            @id @default(autoincrement())
  sku               String         @unique
  itemName          String
  categoryId        String?
  supplier          String?
  unitOfMeasure     String
  receivedQuantity  Int
  unitCost          Decimal        @db.Decimal(12, 2)
  totalValue        Decimal        @db.Decimal(14, 2)
  warehouseLocation String
  receivedDate      DateTime
  reorderLevel      Int
  expiryDate        DateTime?
  description       String?        // Product description for storefront display
  stockImg          String?        // Product image path (e.g. /uploads/stock_images/...)
  adminId           String
  admin             Admin          @relation(fields: [adminId], references: [id])
  category          Category?      @relation(fields: [categoryId], references: [id])
  stockhistory      StockHistory[]
  stockout          StockOut[]
  proformaItems     ProformaInvoiceItem[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([sku])
  @@index([adminId], map: "Stock_adminId_fkey")
  @@index([categoryId], map: "Stock_categoryId_fkey")
}

model Job {
  id               String          @id @default(uuid())
  title            String
  description      String?         @db.Text
  location         String
  employment_type  EmploymentType
  experience_level ExperienceLevel
  industry         String?
  skills_required  String          @db.LongText
  status           JobStatus       @default(OPEN)
  posted_at        DateTime?       @default(now())
  expiry_date      DateTime?
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  applicants       Applicant[]
}

model Applicant {
  id              String           @id @default(uuid())
  jobId           String
  name            String
  email           String
  phone           String?
  cvUrl           String?
  skills          String?          @db.LongText
  experienceYears Int?
  education       String?          @db.LongText
  coverLetter     String?          @db.Text
  start_date      DateTime?
  stage           ApplicationStage @default(APPLIED)
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  job             Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId], map: "Applicant_jobId_fkey")
}

model Client {
  id           String       @id @default(uuid())
  firstname    String
  lastname     String
  email        String
  phone        String?
  address      String?
  status       ClientStatus @default(ACTIVE)
  profileImage String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  adminId      String?
  admin        Admin?       @relation(fields: [adminId], references: [id])

  @@index([adminId], map: "Client_adminId_fkey")
}

model Activity {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  adminId     String?
  employeeId  String?
  admin       Admin?    @relation(fields: [adminId], references: [id])
  employee    Employee? @relation(fields: [employeeId], references: [id])

  @@index([adminId], map: "Activity_adminId_fkey")
  @@index([employeeId], map: "Activity_employeeId_fkey")
}

model Asset {
  id               String             @id @default(uuid())
  name             String
  category         AssetCategory
  description      String?
  assetImg         String?
  location         String?
  quantity         String
  purchaseDate     DateTime?
  purchaseCost     Float?
  status           AssetStatus        @default(ACTIVE)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  AssetRequestItem AssetRequestItem[]
}

model Store {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  location      String
  description   String?   @db.Text
  managerId     String?
  adminId       String
  contact_phone String?
  contact_email String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  stockins      StockIn[]
  admin         Admin     @relation(fields: [adminId], references: [id])
  manager       Employee? @relation(fields: [managerId], references: [id], onDelete: Cascade)

  @@index([adminId], map: "Store_adminId_fkey")
  @@index([managerId], map: "Store_managerId_fkey")
}

model Site {
  id           String     @id @default(uuid())
  siteCode     String     @unique
  name         String
  location     String
  siteImg      String?
  managerId    String?
  supervisorId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  employees    Employee[] @relation("SiteEmployees")
  request      Request[]
  manager      Employee?  @relation("ManagerRelation", fields: [managerId], references: [id], onDelete: Cascade, map: "Site_manager_fkey")
  supervisor   Employee?  @relation("SupervisorRelation", fields: [supervisorId], references: [id], onDelete: Cascade, map: "Site_supervisor_fkey")

  @@index([managerId], map: "Site_manager_fkey")
  @@index([supervisorId], map: "Site_supervisor_fkey")
}

model Cage {
  id           String       @id @default(uuid())
  cageCode     String       @unique
  cageName     String
  cageNetType  CageNetType
  cageDepth    Float
  cageStatus   CageStatus
  cageCapacity Int
  cageType     String?
  cageVolume   Float?
  stockingDate DateTime?
  createdAt    DateTime     @default(now())
  feeds        FeedCage[]
  Medication   Medication[]
}

model Medication {
  id                     String           @id @default(uuid())
  name                   String
  dosage                 String
  method                 MedicationMethod
  reason                 String?
  startDate              DateTime
  endDate                DateTime?
  cageId                 String
  administeredByEmployee String?
  administeredByAdmin    String?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  admin                  Admin?           @relation(fields: [administeredByAdmin], references: [id], onDelete: Cascade)
  employee               Employee?        @relation(fields: [administeredByEmployee], references: [id], onDelete: Cascade)
  cage                   Cage             @relation(fields: [cageId], references: [id], onDelete: Cascade)

  @@index([administeredByAdmin], map: "Medication_administeredByAdmin_fkey")
  @@index([administeredByEmployee], map: "Medication_administeredByEmployee_fkey")
  @@index([cageId], map: "Medication_cageId_fkey")
}

model FeedCage {
  id            String    @id @default(uuid())
  quantityGiven Float
  notes         String?
  cageId        String
  feedId        String
  employeeId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  cage          Cage      @relation(fields: [cageId], references: [id], onDelete: Cascade)
  employee      Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  feed          FeedStock @relation(fields: [feedId], references: [id])

  @@index([cageId])
  @@index([employeeId])
  @@index([feedId], map: "FeedCage_feedId_fkey")
}

model StockCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  stockins    StockIn[]
}

model StockIn {
  id                String            @id @default(uuid())
  productName       String
  sku               String?           @unique
  quantity          Int               @default(0)
  unit              Unit
  unitPrice         Decimal           @db.Decimal(10, 2)
  reorderLevel      Int?              @default(1)
  supplier          String?
  location          String?
  description       String?
  stockcategoryId   String
  storeId           String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  expiryDate        DateTime?
  batchNumber       String?
  grnItemId         String?           @unique
  inspectionStatus  InspectionStatus? @default(APPROVED)
  landedCost        Decimal?          @db.Decimal(10, 2)
  manufacturingDate DateTime?
  qualityNotes      String?           @db.Text
  serialNumbers     String?           @db.LongText
  valuationMethod   ValuationMethod?  @default(WEIGHTED_AVERAGE)
  grnItem           GRNItem?          @relation("StockInGRNItem")
  requestItems      RequestItem[]
  stockhistory      StockHistory[]
  stockcategory     StockCategory     @relation(fields: [stockcategoryId], references: [id])
  store             Store             @relation(fields: [storeId], references: [id])

  @@index([batchNumber])
  @@index([stockcategoryId], map: "StockIn_stockcategoryId_fkey")
  @@index([storeId], map: "StockIn_storeId_fkey")
}

model StockOut {
  id               String            @id @default(uuid())
  stockinId        Int?
  adminId          String?
  employeeId       String?
  transactionId    String?
  quantity         Int               @default(0)
  soldPrice        Decimal?          @db.Decimal(10, 2)
  clientName       String?
  clientEmail      String?
  clientPhone      String?
  paymentMethod    PaymentMethod?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  externalItemName String?
  externalSku      String?
  Debit            Debit[]
  salesReturnItems SalesReturnItem[]
  admin            Admin?            @relation(fields: [adminId], references: [id], onDelete: Cascade)
  employee         Employee?         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  stockin          Stock?            @relation(fields: [stockinId], references: [id], onDelete: Cascade)

  @@index([adminId], map: "StockOut_adminId_fkey")
  @@index([employeeId], map: "StockOut_employeeId_fkey")
  @@index([stockinId], map: "StockOut_stockinId_fkey")
}

model SalesReturn {
  id            String            @id @default(uuid())
  transactionId String?
  creditnoteId  String?
  adminId       String
  reason        String?
  createdAt     DateTime          @default(now())
  items         SalesReturnItem[]
}

model SalesReturnItem {
  id            String      @id @default(uuid())
  salesReturnId String
  stockoutId    String
  quantity      Int
  salesReturn   SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  stockout      StockOut    @relation(fields: [stockoutId], references: [id], onDelete: Cascade)

  @@index([salesReturnId], map: "SalesReturnItem_salesReturnId_fkey")
  @@index([stockoutId], map: "SalesReturnItem_stockoutId_fkey")
}

model Request {
  id                    String         @id @default(uuid())
  ref_no                String         @unique @db.VarChar(50)
  siteId                String
  requestedByAdminId    String?
  requestedByEmployeeId String?
  status                RequestStatus  @default(PENDING)
  notes                 String?        @db.Text
  receivedAt            DateTime?
  closedAt              DateTime?
  closedByAdminId       String?
  closedByEmployeeId    String?
  issuedAt              DateTime?
  issuedByAdminId       String?
  issuedByEmployeeId    String?
  rejectedAt            DateTime?
  rejectedByAdminId     String?
  rejectedByEmployeeId  String?
  comments              String?        @db.LongText
  attachments           String?        @db.LongText
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  closedByAdmin         Admin?         @relation("ClosedByAdmin", fields: [closedByAdminId], references: [id])
  closedByEmployee      Employee?      @relation("ClosedByEmployee", fields: [closedByEmployeeId], references: [id])
  issuedByAdmin         Admin?         @relation("IssuedByAdmin", fields: [issuedByAdminId], references: [id])
  issuedByEmployee      Employee?      @relation("IssuedByEmployee", fields: [issuedByEmployeeId], references: [id])
  rejectedByAdmin       Admin?         @relation("rejectedByAdmin", fields: [rejectedByAdminId], references: [id])
  rejectedByEmployee    Employee?      @relation("rejectedByEmployee", fields: [rejectedByEmployeeId], references: [id])
  requestedByAdmin      Admin?         @relation("RequestedByAdmin", fields: [requestedByAdminId], references: [id])
  requestedByEmployee   Employee?      @relation("RequestedByEmployee", fields: [requestedByEmployeeId], references: [id])
  site                  Site           @relation(fields: [siteId], references: [id])
  requestItems          RequestItem[]
  stockhistory          StockHistory[]

  @@index([closedByAdminId], map: "Request_closedByAdminId_fkey")
  @@index([closedByEmployeeId], map: "Request_closedByEmployeeId_fkey")
  @@index([issuedByAdminId], map: "Request_issuedByAdminId_fkey")
  @@index([issuedByEmployeeId], map: "Request_issuedByEmployeeId_fkey")
  @@index([rejectedByAdminId], map: "Request_rejectedByAdminId_fkey")
  @@index([rejectedByEmployeeId], map: "Request_rejectedByEmployeeId_fkey")
  @@index([requestedByAdminId], map: "Request_requestedByAdminId_fkey")
  @@index([requestedByEmployeeId], map: "Request_requestedByEmployeeId_fkey")
  @@index([siteId], map: "Request_siteId_fkey")
}

model RequestItem {
  id           String   @id @default(uuid())
  requestId    String
  stockInId    String
  qtyRequested Decimal  @db.Decimal(12, 3)
  qtyIssued    Decimal  @default(0.000) @db.Decimal(12, 3)
  qtyRemaining Decimal  @default(0.000) @db.Decimal(12, 3)
  qtyReceived  Decimal? @default(0.000) @db.Decimal(12, 3)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  request      Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  stockIn      StockIn  @relation(fields: [stockInId], references: [id], onDelete: Cascade)

  @@index([requestId], map: "RequestItem_requestId_fkey")
  @@index([stockInId], map: "RequestItem_stockInId_fkey")
}

model AssetRequest {
  id          String             @id @default(uuid())
  employeeId  String
  status      RequestStatus      @default(PENDING)
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  employee    Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  items       AssetRequestItem[]

  @@index([employeeId], map: "AssetRequest_employeeId_fkey")
}

model AssetRequestItem {
  id                String              @id @default(uuid())
  requestId         String
  assetId           String
  quantity          Int                 @default(1)
  quantityIssued    Int?                @default(0)
  status            RequestedItemStatus @default(PENDING)
  procurementStatus ProcurementStatus   @default(NOT_REQUIRED)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  asset             Asset               @relation(fields: [assetId], references: [id], onDelete: Cascade)
  request           AssetRequest        @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([assetId], map: "AssetRequestItem_assetId_fkey")
  @@index([requestId], map: "AssetRequestItem_requestId_fkey")
}

model StockHistory {
  id                  String              @id @default(uuid())
  stockInId           String?
  movementType        MovementType
  sourceType          SourceType
  sourceId            String?
  qtyBefore           Decimal             @db.Decimal(12, 3)
  qtyChange           Decimal             @db.Decimal(12, 3)
  qtyAfter            Decimal             @db.Decimal(12, 3)
  unitPrice           Decimal?            @db.Decimal(12, 2)
  notes               String?             @db.Text
  createdByAdminId    String?
  createdByEmployeeId String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  stockId             Int?
  batchNumber         String?
  costAtTransaction   Decimal?            @db.Decimal(12, 2)
  grnId               String?
  valuationMethod     ValuationMethod?
  createdByAdmin      Admin?              @relation(fields: [createdByAdminId], references: [id])
  createdByEmployee   Employee?           @relation(fields: [createdByEmployeeId], references: [id])
  grn                 GoodsReceivingNote? @relation("GRNStockHistory", fields: [grnId], references: [id])
  request             Request?            @relation(fields: [sourceId], references: [id])
  stock               Stock?              @relation(fields: [stockId], references: [id], onDelete: Cascade)
  stockIn             StockIn?            @relation(fields: [stockInId], references: [id], onDelete: Cascade)

  @@index([createdByAdminId], map: "StockHistory_createdByAdminId_fkey")
  @@index([createdByEmployeeId], map: "StockHistory_createdByEmployeeId_fkey")
  @@index([grnId], map: "StockHistory_grnId_fkey")
  @@index([sourceId], map: "StockHistory_sourceId_fkey")
  @@index([stockId], map: "StockHistory_stockId_fkey")
  @@index([stockInId], map: "StockHistory_stockInId_fkey")
}

model ParentFishPool {
  id                   String                 @id @default(uuid())
  name                 String                 @unique
  description          String?
  numberOfFishes       Int?
  employeeId           String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  parentEggMigration   ParentEggMigration[]
  ParentFishFeeding    ParentFishFeeding[]
  ParentFishMedication ParentFishMedication[]
  employee             Employee?              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  parentWaterChanging  ParentWaterChanging[]

  @@index([employeeId], map: "ParentFishPool_employeeId_fkey")
}

model Medicine {
  id                   String                 @id @default(uuid())
  name                 String
  description          String?
  dosageForm           DosageForm
  quantity             Float
  unit                 String
  purchaseDate         DateTime?
  expiryDate           DateTime?
  pricePerUnit         Float?
  totalCost            Float?
  addedById            String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  EggFishMedication    EggFishMedication[]
  employee             Employee?              @relation(fields: [addedById], references: [id])
  ParentFishMedication ParentFishMedication[]
  PondMedication       PondMedication[]

  @@index([addedById], map: "Medicine_addedById_fkey")
}

model FeedStock {
  id                  String                @id @default(uuid())
  name                String
  quantity            Int                   @default(0)
  lowStockLevel       Int?                  @default(1)
  category            String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  eggFishFeeding      EggFishFeeding[]
  feedCage            FeedCage[]
  grownEggPondFeeding GrownEggPondFeeding[]
  ParentFishFeeding   ParentFishFeeding[]
}

model ParentFishFeeding {
  id               String         @id @default(uuid())
  parentFishPoolId String
  feedId           String
  employeeId       String
  quantity         Int            @default(0)
  createdAt        DateTime       @default(now())
