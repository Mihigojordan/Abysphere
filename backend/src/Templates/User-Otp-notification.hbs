<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Your OTP Code — Papeterie Messenger Supplier Ltd</title>
</head>
<body style="margin:0;padding:0;background-color:#f0f6ff;font-family:Arial,Helvetica,sans-serif;-webkit-text-size-adjust:100%;">

  <div style="display:none;max-height:0;overflow:hidden;font-size:1px;line-height:1px;color:#f0f6ff;opacity:0;">Your one-time verification code is inside.</div>

  <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background:#f0f6ff;padding:32px 16px;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" role="presentation" style="max-width:600px;width:100%;background:#ffffff;border:1px solid #bfdbfe;border-radius:4px;overflow:hidden;box-shadow:0 4px 20px rgba(30,58,138,0.08);">

          <!-- Gold top bar -->
          <tr><td style="height:4px;background:#daa13c;font-size:0;line-height:0;">&nbsp;</td></tr>

          <!-- Header -->
          <tr>
            <td style="background:#1e3a8a;padding:32px 40px;text-align:center;">
              <div style="font-family:Georgia,'Times New Roman',serif;font-size:11px;letter-spacing:0.18em;color:#daa13c;text-transform:uppercase;margin-bottom:6px;">Est. Kigali, Rwanda</div>
              <div style="font-family:Georgia,'Times New Roman',serif;font-size:26px;font-weight:700;color:#ffffff;letter-spacing:0.02em;line-height:1.2;">Papeterie Messenger Supplier Ltd</div>
              <div style="width:48px;height:2px;background:#daa13c;margin:14px auto 0;"></div>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding:36px 40px 28px;">
              <h2 style="font-family:Georgia,'Times New Roman',serif;font-size:22px;font-weight:400;color:#1e3a8a;margin:0 0 14px;letter-spacing:0.01em;">Verification Code</h2>
              <p style="font-size:15px;color:#374151;line-height:1.7;margin:0 0 24px;">Hi {{firstname}}, use the one-time password below to verify your account. This code is valid for <strong>{{validityMinutes}} minutes</strong> and cannot be shared.</p>

              <!-- OTP block -->
              <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin:0 0 28px;">
                <tr>
                  <td align="center" style="background:#1e3a8a;border-radius:4px;padding:28px 20px;">
                    <div style="font-family:Georgia,'Times New Roman',serif;font-size:11px;letter-spacing:0.18em;color:#daa13c;text-transform:uppercase;margin-bottom:10px;">Your OTP</div>
                    <div style="font-family:Georgia,'Times New Roman',serif;font-size:46px;font-weight:700;color:#ffffff;letter-spacing:0.18em;line-height:1;">{{otp}}</div>
                  </td>
                </tr>
              </table>

              <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="border-left:3px solid #daa13c;background:#fffbeb;border-radius:0 3px 3px 0;margin:0 0 20px;">
                <tr><td style="padding:12px 16px;font-size:13px;color:#92400e;line-height:1.5;">
                  If you did not request this code, please ignore this email. Your account remains secure.
                </td></tr>
              </table>

              <p style="font-size:14px;color:#64748b;line-height:1.6;margin:0;">Never share your OTP with anyone, including our staff.</p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f8fafc;border-top:3px solid #daa13c;padding:24px 40px;text-align:center;">
              <p style="font-family:Georgia,'Times New Roman',serif;font-size:14px;font-weight:700;color:#1e3a8a;margin:0 0 6px;letter-spacing:0.02em;">Papeterie Messenger Supplier Ltd</p>
              <p style="font-size:12px;color:#64748b;margin:0 0 4px;">Kigali, Rwanda &nbsp;|&nbsp; +250 784 544 729 &nbsp;|&nbsp; papemessenger@gmail.com</p>
              <p style="font-size:11px;color:#94a3b8;margin:12px 0 0;">&copy; {{year}} Papeterie Messenger Supplier Ltd. All rights reserved.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
