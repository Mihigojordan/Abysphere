<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Subscription Activated — Papeterie Messenger Supplier Ltd</title>
</head>
<body style="margin:0;padding:0;background-color:#f0f6ff;font-family:Arial,Helvetica,sans-serif;-webkit-text-size-adjust:100%;">

  <div style="display:none;max-height:0;overflow:hidden;font-size:1px;line-height:1px;color:#f0f6ff;opacity:0;">Your subscription is now active — full access confirmed.</div>

  <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background:#f0f6ff;padding:32px 16px;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" role="presentation" style="max-width:600px;width:100%;background:#ffffff;border:1px solid #bfdbfe;border-radius:4px;overflow:hidden;box-shadow:0 4px 20px rgba(30,58,138,0.08);">

          <tr><td style="height:4px;background:#daa13c;font-size:0;line-height:0;">&nbsp;</td></tr>

          <tr>
            <td style="background:#1e3a8a;padding:32px 40px;text-align:center;">
              <div style="font-family:Georgia,'Times New Roman',serif;font-size:11px;letter-spacing:0.18em;color:#daa13c;text-transform:uppercase;margin-bottom:6px;">Est. Kigali, Rwanda</div>
              <div style="font-family:Georgia,'Times New Roman',serif;font-size:26px;font-weight:700;color:#ffffff;letter-spacing:0.02em;line-height:1.2;">Papeterie Messenger Supplier Ltd</div>
              <div style="width:48px;height:2px;background:#daa13c;margin:14px auto 0;"></div>
            </td>
          </tr>

          <tr>
            <td style="padding:36px 40px 28px;">
              <h2 style="font-family:Georgia,'Times New Roman',serif;font-size:22px;font-weight:400;color:#1e3a8a;margin:0 0 18px;letter-spacing:0.01em;">Hello, {{clientName}}</h2>

              <!-- Success badge -->
              <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin:0 0 24px;">
                <tr>
                  <td align="center" style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:4px;padding:16px 24px;">
                    <div style="font-size:13px;font-weight:700;color:#166534;letter-spacing:0.08em;text-transform:uppercase;">&#10003; &nbsp;Subscription Activated Successfully</div>
                  </td>
                </tr>
              </table>

              <p style="font-size:15px;color:#374151;line-height:1.7;margin:0 0 24px;">Your subscription is now active. You have full access to all features included in your plan.</p>

              <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background:#f0f6ff;border:1px solid #bfdbfe;border-radius:4px;margin:0 0 24px;">
                <tr><td style="padding:20px 24px;">
                  <table width="100%" cellpadding="0" cellspacing="0" role="presentation">
                    <tr>
                      <td style="font-size:13px;color:#64748b;padding:5px 0;width:140px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;">Plan</td>
                      <td style="font-size:13px;color:#1e3a8a;padding:5px 0;font-weight:700;">{{planName}}</td>
                    </tr>
                    <tr><td colspan="2" style="height:1px;background:#bfdbfe;padding:0;font-size:0;"></td></tr>
                    <tr>
                      <td style="font-size:13px;color:#64748b;padding:5px 0;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;">Valid Until</td>
                      <td style="font-size:13px;color:#1e3a8a;padding:5px 0;font-weight:700;">{{validUntil}}</td>
                    </tr>
                  </table>
                </td></tr>
              </table>

              <table cellpadding="0" cellspacing="0" role="presentation" style="margin:8px 0 20px;">
                <tr>
                  <td style="background:#1e3a8a;border-radius:3px;">
                    <a href="{{loginUrl}}" style="display:inline-block;padding:13px 32px;font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;color:#ffffff;text-decoration:none;letter-spacing:0.05em;text-transform:uppercase;">Go to Dashboard</a>
                  </td>
                </tr>
              </table>

              <p style="font-size:14px;color:#64748b;line-height:1.6;margin:0;">Thank you for choosing Papeterie Messenger Supplier Ltd. We remain available for any support you may need.</p>
            </td>
          </tr>

          <tr>
            <td style="background:#f8fafc;border-top:3px solid #daa13c;padding:24px 40px;text-align:center;">
              <p style="font-family:Georgia,'Times New Roman',serif;font-size:14px;font-weight:700;color:#1e3a8a;margin:0 0 6px;letter-spacing:0.02em;">Papeterie Messenger Supplier Ltd</p>
              <p style="font-size:12px;color:#64748b;margin:0 0 4px;">Kigali, Rwanda &nbsp;|&nbsp; +250 784 544 729 &nbsp;|&nbsp; papemessenger@gmail.com</p>
              <p style="font-size:11px;color:#94a3b8;margin:12px 0 0;">&copy; {{year}} Papeterie Messenger Supplier Ltd. All rights reserved.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
