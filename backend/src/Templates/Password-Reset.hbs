<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Password Reset — Papeterie Messenger Supplier Ltd</title>
</head>
<body style="margin:0;padding:0;background-color:#f0f6ff;font-family:Arial,Helvetica,sans-serif;-webkit-text-size-adjust:100%;">

  <div style="display:none;max-height:0;overflow:hidden;font-size:1px;line-height:1px;color:#f0f6ff;opacity:0;">Reset your password — link inside, valid for limited time.</div>

  <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background:#f0f6ff;padding:32px 16px;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" role="presentation" style="max-width:600px;width:100%;background:#ffffff;border:1px solid #bfdbfe;border-radius:4px;overflow:hidden;box-shadow:0 4px 20px rgba(30,58,138,0.08);">

          <!-- Gold top bar -->
          <tr><td style="height:4px;background:#daa13c;font-size:0;line-height:0;">&nbsp;</td></tr>

          <!-- Header -->
          <tr>
            <td style="background:#1e3a8a;padding:32px 40px;text-align:center;">
              <div style="font-family:Georgia,'Times New Roman',serif;font-size:11px;letter-spacing:0.18em;color:#daa13c;text-transform:uppercase;margin-bottom:6px;">Est. Kigali, Rwanda</div>
              <div style="font-family:Georgia,'Times New Roman',serif;font-size:26px;font-weight:700;color:#ffffff;letter-spacing:0.02em;line-height:1.2;">Papeterie Messenger Supplier Ltd</div>
              <div style="width:48px;height:2px;background:#daa13c;margin:14px auto 0;"></div>
            </td>
          </tr>

          <!-- Content -->
          <tr>
            <td style="padding:36px 40px 28px;">

              <!-- Icon area -->
              <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin:0 0 22px;">
                <tr>
                  <td align="center">
                    <div style="display:inline-block;width:56px;height:56px;background:#f0f6ff;border:2px solid #bfdbfe;border-radius:50%;text-align:center;line-height:52px;font-size:26px;">&#128274;</div>
                  </td>
                </tr>
              </table>

              <h2 style="font-family:Georgia,'Times New Roman',serif;font-size:22px;font-weight:400;color:#1e3a8a;margin:0 0 14px;letter-spacing:0.01em;text-align:center;">Password Reset Request</h2>
              <p style="font-size:15px;color:#374151;line-height:1.7;margin:0 0 14px;text-align:center;">We received a request to reset the password for your account. Click the button below to set a new password.</p>

              <!-- CTA -->
              <table cellpadding="0" cellspacing="0" role="presentation" style="margin:24px auto;">
                <tr>
                  <td align="center" style="background:#1e3a8a;border-radius:3px;">
                    <a href="{{resetLink}}" style="display:inline-block;padding:13px 36px;font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;color:#ffffff;text-decoration:none;letter-spacing:0.05em;text-transform:uppercase;">Reset Password</a>
                  </td>
                </tr>
              </table>

              <p style="font-size:13px;color:#64748b;line-height:1.6;margin:0 0 8px;">Or copy and paste this link into your browser:</p>
              <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="background:#f0f6ff;border:1px solid #bfdbfe;border-radius:3px;margin:0 0 20px;">
                <tr><td style="padding:12px 16px;font-size:12px;color:#2563eb;word-break:break-all;">
                  <a href="{{resetLink}}" style="color:#2563eb;text-decoration:none;">{{resetLink}}</a>
                </td></tr>
              </table>

              <table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="border-left:3px solid #daa13c;background:#fffbeb;border-radius:0 3px 3px 0;">
                <tr><td style="padding:12px 16px;font-size:13px;color:#92400e;line-height:1.5;">
                  <strong>Didn't request this?</strong> If you did not request a password reset, please ignore this email. Your password will remain unchanged.
                </td></tr>
              </table>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background:#f8fafc;border-top:3px solid #daa13c;padding:24px 40px;text-align:center;">
              <p style="font-family:Georgia,'Times New Roman',serif;font-size:14px;font-weight:700;color:#1e3a8a;margin:0 0 6px;letter-spacing:0.02em;">Papeterie Messenger Supplier Ltd</p>
              <p style="font-size:12px;color:#64748b;margin:0 0 4px;">Kigali, Rwanda &nbsp;|&nbsp; +250 784 544 729 &nbsp;|&nbsp; papemessenger@gmail.com</p>
              <p style="font-size:11px;color:#94a3b8;margin:12px 0 0;">&copy; {{year}} Papeterie Messenger Supplier Ltd. All rights reserved.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
